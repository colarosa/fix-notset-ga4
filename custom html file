<script>
(function() {

  var loc = window.location;
  var url = loc.href;

  if (url.indexOf("utm_") > -1) return;

  var paid = [
    "gclid","gclsrc","gbraid","wbraid","dclid",
    "fbclid","msclkid","ttclid","twclid",
    "li_fat_id","yclid","epik"
  ];

  for (var i=0;i<paid.length;i++){
    if (url.indexOf(paid[i]+"=") > -1) return;
  }

  var q = loc.search.toLowerCase();
  if (q.indexOf("clid=") > -1) return;
  if (q.indexOf("clickid=") > -1) return;

  var ref = document.referrer;

  var source = "(direct)";
  var medium = "(none)";
  var campaign = "auto";

  if (ref) {

    var parser = document.createElement("a");
    parser.href = ref;

    source = parser.hostname.replace("www.","");
    medium = "referral";

    var search = ["google.","bing.","duckduckgo.","yahoo.","baidu.","yandex.","ecosia.","naver."];
    for(i=0;i<search.length;i++){
      if(source.indexOf(search[i])>-1) medium="organic";
    }

    var social = ["facebook.","instagram.","linkedin.","twitter.","t.co","reddit.","pinterest.","tiktok."];
    for(i=0;i<social.length;i++){
      if(source.indexOf(social[i])>-1) medium="social";
    }

    var email = ["mail.","outlook.","gmail.","hotmail.","yahoo.","icloud."];
    for(i=0;i<email.length;i++){
      if(source.indexOf(email[i])>-1) medium="email";
    }

    var messaging = ["whatsapp.","t.me","telegram.","slack.","discord.","messenger."];
    for(i=0;i<messaging.length;i++){
      if(source.indexOf(messaging[i])>-1) medium="messaging";
    }

    var ai = ["chatgpt","openai","perplexity","claude","poe.com","phind","you.com"];
    for(i=0;i<ai.length;i++){
      if(source.indexOf(ai[i])>-1) medium="ai";
    }

  } else {

    medium = "dark_social";

    var ua = navigator.userAgent.toLowerCase();

    if (ua.indexOf("iphone")>-1 || ua.indexOf("ipad")>-1){
      source = "ios_share";
    }
    else if (ua.indexOf("android")>-1){
      source = "android_share";
    }
    else{
      source = "direct_share";
    }
  }

  var newParams =
    "utm_source=" + encodeURIComponent(source) +
    "&utm_medium=" + encodeURIComponent(medium) +
    "&utm_campaign=" + encodeURIComponent(campaign);

  var newUrl;

  if (loc.search.length > 0) {
    newUrl = loc.pathname + loc.search + "&" + newParams + loc.hash;
  } else {
    newUrl = loc.pathname + "?" + newParams + loc.hash;
  }

  history.replaceState({}, "", newUrl);

})();
</script>
