<script>
(function(){

  var url = window.location.href;
  var parser = document.createElement('a');
  parser.href = url;

  var params = parser.search.substring(1).split("&");
  var paramsObj = {};
  for(var i=0; i<params.length; i++){
    if(params[i]){
      var pair = params[i].split("=");
      paramsObj[decodeURIComponent(pair[0])] = pair[1] ? decodeURIComponent(pair[1]) : "";
    }
  }

  // --- 1. Exit if UTM exists
  if(paramsObj["utm_source"]) return;

  // --- 2. Exit if paid click identifiers exist
  var adParams = [
    "gclid","gclsrc","gbraid","wbraid","dclid",
    "fbclid","msclkid","ttclid","twclid",
    "li_fat_id","yclid","epik"
  ];
  for(i=0; i<adParams.length; i++){
    if(paramsObj[adParams[i]]) return;
  }

  // Generic future-proof ad detection
  for(var key in paramsObj){
    if(paramsObj.hasOwnProperty(key)){
      if(key.length >= 4 && key.substring(key.length-4)==="clid") return;
      if(key.length >= 7 && key.substring(key.length-7)==="clickid") return;
    }
  }

  // --- 3. Initialize defaults
  var source = "(direct)";
  var medium = "(none)";
  var campaign = "direct";

  // --- 4. Capture referrer
  var ref = document.referrer;
  if(ref){
    try{
      source = ref.replace(/^https?:\/\/(www\.)?/, '').split("/")[0];
    }catch(e){}
    medium = "referral";

    // --- 5. Channel classification
    var search = ["google.","bing.","duckduckgo.","yahoo.","baidu.","yandex.","ecosia.","naver."];
    for(i=0;i<search.length;i++){ if(source.indexOf(search[i])!==-1) medium="organic"; }

    var social = ["facebook.","instagram.","twitter.","t.co","linkedin.","reddit.","pinterest.","tiktok.","snapchat."];
    for(i=0;i<social.length;i++){ if(source.indexOf(social[i])!==-1) medium="social"; }

    var email = ["mail.google.","outlook.","hotmail.","live.com","mail.yahoo.","icloud.","proton.","hey.com"];
    for(i=0;i<email.length;i++){ if(source.indexOf(email[i])!==-1) medium="email"; }

    var messaging = ["whatsapp.","l.whatsapp.","t.me","telegram.","slack.","discord.","messenger."];
    for(i=0;i<messaging.length;i++){ if(source.indexOf(messaging[i])!==-1) medium="messaging"; }

    var ai = ["chat.openai.com","chatgpt.com","perplexity.ai","claude.ai","poe.com","phind.com","you.com"];
    for(i=0;i<ai.length;i++){ if(source.indexOf(ai[i])!==-1) medium="ai"; }

    var dev = ["github.","stackoverflow.","stackexchange.","news.ycombinator.","hackernews.","producthunt."];
    for(i=0;i<dev.length;i++){ if(source.indexOf(dev[i])!==-1) medium="community"; }
  }

  // --- 6. Dark social / copied link detection
  if(!ref && params.length===1 && params[0]===""){
    medium = "dark_social";

    // --- 6a. Fingerprint by user agent
    var ua = navigator.userAgent.toLowerCase();
    if(ua.indexOf("iphone")!==-1 || ua.indexOf("ipad")!==-1){
      if(ua.indexOf("safari")!==-1 && ua.indexOf("crios")===-1) source = "iMessage_share";
      else source = "ios_app_share";
    } else if(ua.indexOf("android")!==-1){
      source = "android_app_share";
    } else {
      source = "unknown_share";
    }

    // --- 6b. Hash-based UTM detection
    var hash = window.location.hash.substring(1);
    if(hash && hash.indexOf("utm")!==-1){
      try{
        var hashParams = hash.split("&");
        for(i=0;i<hashParams.length;i++){
          var pair = hashParams[i].split("=");
          var k = decodeURIComponent(pair[0]);
          var v = pair[1] ? decodeURIComponent(pair[1]) : "";
          if(k==="utm_source") source = v;
          if(k==="utm_medium") medium = v;
          if(k==="utm_campaign") campaign = v;
        }
      }catch(e){}
    }
  }

  // --- 7. Store session attribution
  sessionStorage.setItem("attr_session_source",source);
  sessionStorage.setItem("attr_session_medium",medium);
  sessionStorage.setItem("attr_session_campaign",campaign);

  // --- 8. Store first-touch attribution (only once)
  if(!localStorage.getItem("attr_first_source")){
    localStorage.setItem("attr_first_source",source);
    localStorage.setItem("attr_first_medium",medium);
    localStorage.setItem("attr_first_campaign",campaign);
  }

  // --- 9. Push to dataLayer
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({
    event: "attr_attribution_ready",
    attr_session_source: source,
    attr_session_medium: medium,
    attr_session_campaign: campaign,
    attr_first_source: localStorage.getItem("attr_first_source"),
    attr_first_medium: localStorage.getItem("attr_first_medium"),
    attr_first_campaign: localStorage.getItem("attr_first_campaign")
  });

})();
</script>
